# --- Base de données (métadonnées uniquement, jamais les fichiers) ---
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/frigo?retryWrites=true&w=majority

# --- Stockage fichiers (Vercel Blob, mode privé) ---
# Fourni automatiquement par Vercel quand un store Blob est lié au projet.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# --- Authentification ---
# Identifiant unique (application mono-utilisateur)
AUTH_EMAIL=vous@example.com
# Hash bcrypt du mot de passe — générer avec : npm run hash-password
AUTH_PASSWORD_HASH=$2b$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Secret de signature des JWT — 64 caractères aléatoires minimum
JWT_SECRET=changez-moi-64-caracteres-aleatoires-minimum

# --- 2FA TOTP (optionnel mais recommandé) ---
# Si défini, un code TOTP est exigé au login. Générer avec : npm run totp-secret
# Laisser vide pour désactiver la 2FA.
TOTP_SECRET=

# --- Serveur MCP ---
# Jeton Bearer exigé par le connecteur Claude. Générer une longue valeur aléatoire.
MCP_ACCESS_TOKEN=changez-moi-jeton-aleatoire-long

# --- LLM Gemini (chatbot documentaire, résumé auto, analyse auto à l'upload) ---
# server/lib/llm.js (résumé + analyse), server/lib/llm-chat.js (chat, streaming
# + tool calling). Clé API Google Gemini — gratuite, sans carte bancaire requise.
# À générer sur https://aistudio.google.com/apikey (bouton "Create API key").
GEMINI_API_KEY=

# --- Divers ---
# 'production' sur Vercel (cookies Secure). Laisser vide en dev local.
# NODE_ENV=production
